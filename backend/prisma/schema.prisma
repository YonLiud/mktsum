generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id       String    @id
  name          String
  ntfy_topic    String
  created_at    DateTime  @default(now())

  watchlist     Watchlist[]
  briefing      Briefing[]
}

model Watchlist {
  watchlist_id  String    @id
  user_id       String
  ticker        String

  user          User      @relation(fields: [user_id], references: [user_id])

  @@unique([user_id, ticker])
}

model Briefing {
  briefing_id   String    @id
  user_id       String
  full_summary  String
  short_summary String
  sources       String?
  created_at    DateTime  @default(now())

  user          User      @relation(fields: [user_id], references: [user_id])
}

